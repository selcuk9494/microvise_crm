default_platform(:ios)

platform :ios do
  lane :testflight do
    key_id = ENV["ASC_KEY_ID"].to_s.strip
    issuer_id = ENV["ASC_ISSUER_ID"].to_s.strip
    key_content = ENV["ASC_KEY_CONTENT"].to_s.strip
    key_path = ENV["ASC_KEY_PATH"].to_s.strip

    if key_id.empty? || issuer_id.empty?
      UI.user_error!("ASC_KEY_ID ve ASC_ISSUER_ID zorunludur.")
    end

    api_key =
      if !key_path.empty? && File.exist?(key_path)
        app_store_connect_api_key(
          key_id: key_id,
          issuer_id: issuer_id,
          key_filepath: key_path
        )
      elsif !key_content.empty?
        app_store_connect_api_key(
          key_id: key_id,
          issuer_id: issuer_id,
          key_content: key_content,
          is_key_content_base64: true
        )
      else
        UI.user_error!("ASC_KEY_CONTENT (base64) veya ASC_KEY_PATH (.p8 dosya yolu) zorunludur.")
      end

    sh("flutter pub get")
    sh("flutter build ios --release --no-codesign")

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
